# Server Configuration
PORT=7002
NODE_ENV=development

# ─────────────────────────────────────────────────────────────────────────────
# Database Connection — Supabase (recommended) or local PostgreSQL
# ─────────────────────────────────────────────────────────────────────────────

# DATABASE_URL  → used by the app at runtime (pooler, port 6543)
# Format:  postgresql://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:6543/postgres
DATABASE_URL="postgresql://postgres.YOUR_PROJECT_REF:YOUR_PASSWORD@aws-0-ap-southeast-1.pooler.supabase.com:6543/postgres"

# DIRECT_URL → used by Prisma migrate only (direct connection, port 5432)
# Format:  postgresql://postgres:PASSWORD@db.PROJECT_REF.supabase.co:5432/postgres
DIRECT_URL="postgresql://postgres:YOUR_PASSWORD@db.YOUR_PROJECT_REF.supabase.co:5432/postgres"

# Authentication Secrets
JWT_SECRET="your-super-secret-jwt-key-replace-this-in-production"
COOKIE_SECRET="your-super-secret-cookie-key-replace-this-in-production"
